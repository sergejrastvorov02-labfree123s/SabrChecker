<Window x:Class="SabrChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SabrChecker" 
        Width="1050" Height="580" 
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.2"/>
        </Storyboard>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#3A3A3A" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="Transparent" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Red" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3D0000"/>
            <Setter Property="Foreground" Value="#FFCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#550000" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#550000" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#FF5555" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#3D0000" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#550000" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CopyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#550000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#CC4444" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#550000" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4CAF50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" TextDecorations="Underline"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#66BB6A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Анимированный фоновый градиент -->
        <Border x:Name="BackgroundBorder">
            <Border.Background>
                <LinearGradientBrush x:Name="AnimatedGradient" StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A0A0A" Offset="0"/>
                    <GradientStop Color="#1A0505" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Основное содержимое -->
        <Grid x:Name="MainGrid" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#2D0000" Opacity="0.9">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Логотип сервера (logo.jpg) -->
                    <Border Grid.Row="0" Margin="10,10,10,5" HorizontalAlignment="Center" CornerRadius="20" ClipToBounds="True">
                        <Image x:Name="ServerLogo" Width="80" Height="80" Stretch="UniformToFill"/>
                    </Border>

                    <!-- Заголовок -->
                    <TextBlock Grid.Row="1" Text="SABR CHECKER" FontSize="18" FontWeight="Bold" Foreground="#FF5555" 
                               HorizontalAlignment="Center" Margin="0,5,0,15"/>

                    <!-- Вкладки -->
                    <StackPanel Grid.Row="2" Margin="10,0">
                        <Button x:Name="AppsTabButton" Content="ПРИЛОЖЕНИЯ" Style="{StaticResource SidebarButtonStyle}" Click="AppsTab_Click"/>
                        <Button x:Name="InfoTabButton" Content="ИНФОРМАЦИЯ" Style="{StaticResource SidebarButtonStyle}" Click="InfoTab_Click" Margin="0,10,0,0"/>
                    </StackPanel>

                    <!-- Соцсети -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Button x:Name="GitHubBtn" Width="40" Height="40" Click="OpenLink_Click" Tag="github_url">
                            <Image x:Name="GitHubIcon" Width="24" Height="24"/>
                        </Button>
                        <Button x:Name="TelegramBtn" Width="40" Height="40" Margin="5" Click="OpenLink_Click" Tag="telegram_url">
                            <Image x:Name="TelegramIcon" Width="24" Height="24"/>
                        </Button>
                        <Button x:Name="DiscordBtn" Width="40" Height="40" Margin="5" Click="OpenLink_Click" Tag="discord_url">
                            <Image x:Name="DiscordIcon" Width="24" Height="24"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Кнопки управления -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,15,0">
                    <Button x:Name="MinimizeBtn" Content="_" Style="{StaticResource WindowButtonStyle}" Click="Minimize_Click"/>
                    <Button x:Name="CloseBtn" Content="X" Style="{StaticResource WindowButtonStyle}" Click="Close_Click" Margin="5,0,0,0"/>
                </StackPanel>

                <!-- Вкладка ПРИЛОЖЕНИЯ -->
                <ScrollViewer x:Name="AppsContent" Grid.Row="1" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20">
                        <TextBlock Text="ОСНОВНОЙ СОФТ" FontSize="16" FontWeight="Bold" Foreground="#FF5555" Margin="0,0,0,10"/>
                        <WrapPanel x:Name="MainToolsPanel" Margin="0,0,0,20"/>

                        <TextBlock Text="СИСТЕМНЫЕ УТИЛИТЫ" FontSize="16" FontWeight="Bold" Foreground="#FF5555" Margin="0,15,0,10"/>
                        <Border Background="#3D0000" CornerRadius="8" Padding="12" Margin="0,0,0,20">
                            <WrapPanel>
                                <Button x:Name="ServicesBtn" Content="Службы" Style="{StaticResource ActionButtonStyle}" Click="Services_Click" Width="150" Height="36" Margin="5"/>
                                <Button x:Name="DataUsageBtn" Content="Использование данных" Style="{StaticResource ActionButtonStyle}" Click="DataUsage_Click" Width="170" Height="36" Margin="5"/>
                                <Button x:Name="NvidiaBtn" Content="Nvidia Panel" Style="{StaticResource ActionButtonStyle}" Click="Nvidia_Click" Width="150" Height="36" Margin="5"/>
                            </WrapPanel>
                        </Border>

                        <Border Background="#3D0000" BorderBrush="#FF5555" BorderThickness="1" CornerRadius="8" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="МЕТОД 1" FontSize="16" FontWeight="Bold" Foreground="#FF5555" Margin="0,0,0,10"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="Method1Text" Text="Загрузка..." Foreground="White" TextWrapping="Wrap" FontSize="14"/>
                                    <Button Grid.Column="1" Content="Копировать" Style="{StaticResource ActionButtonStyle}" Click="CopyMethod1_Click" Margin="10,0,0,0" Height="30"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Вкладка ИНФОРМАЦИЯ (открыта по умолчанию) -->
                <ScrollViewer x:Name="InfoContent" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Margin="20,20,20,250" Background="#2D0000" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="О ПРОГРАММЕ" FontSize="22" FontWeight="Bold" Foreground="#FF5555" Margin="0,0,0,15"/>
                                <TextBlock x:Name="AboutText" Text="SabrChecker – инструмент для проверки на читы созданный для проекта SabrRust." 
                                           Foreground="#E0E0E0" FontSize="14" TextWrapping="Wrap"/>
                                <Button x:Name="WebsiteLinkBtn" Content="Сайт проекта (нажми)" Style="{StaticResource LinkButtonStyle}" Click="OpenWebsite_Click" Cursor="Hand" Width="128" Margin="0,-18,-426,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#2D0000" Padding="15,10" CornerRadius="8" Margin="20,458,20,15">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock x:Name="VersionText" Text="Версия: v1.0.5" Foreground="#00ff08" FontWeight="Bold" Margin="0,0,15,0"/>
                                <TextBlock Text=" |  Создатель: Serge (discord: serge6016)" Foreground="#E0E0E0" Margin="-13,0,15,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>

    </Grid>
</Window>